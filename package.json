{
  "name": "connexy",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspaces",
    "build:api": "npm run build --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web",
    "deploy": "npm run deploy --workspace=apps/api && npm run deploy --workspace=apps/web",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "db:push": "wrangler d1 execute connexy --local --file=./infra/cloudflare/schema.sql",
    "db:migrate": "wrangler d1 migrations apply connexy --local"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "wrangler": "^3.60.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}