{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://connexy.dev/contracts/metadata-object.json",
  "title": "MetadataObject",
  "description": "The common internal metadata model — every connector normalizes to this shape.",
  "type": "object",
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "connectorId": { "type": "string", "format": "uuid" },
    "externalId": { "type": "string" },
    "name": { "type": "string" },
    "type": { "type": "string", "enum": ["tag", "field", "table", "entity", "attribute", "measure", "dimension", "hierarchy", "kpi"] },
    "path": { "type": "string" },
    "description": { "type": "string" },
    "dataType": { "type": "string" },
    "unitOfMeasure": { "type": "string" },
    "sampleValues": { "type": "array" },
    "properties": { "type": "object" },
    "lineage": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["source", "transform", "target"] },
          "refId": { "type": "string" },
          "description": { "type": "string" }
        },
        "required": ["type", "refId"]
      }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "required": ["id", "connectorId", "externalId", "name", "type", "properties", "createdAt", "updatedAt"],
  "additionalProperties": false
}